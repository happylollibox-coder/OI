# BigQuery connection (copy to .env and fill)
CUBEJS_DB_TYPE=bigquery
CUBEJS_DB_BQ_PROJECT_ID=onyga-482313
CUBEJS_DB_BQ_KEY_FILE=./bq-key.json
CUBEJS_DB_BQ_LOCATION=US
CUBEJS_SCHEMA_PATH=schema

# OneDrive fix: Put Cube Store data outside OneDrive (Cube Store can't lock files in sync folders)
CUBESTORE_DATA_DIR=/tmp/cube-oi-cubestore
